{
  "name": "mythical-beings-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run typecheck && vite build",
    "format": "eslint src tests supabase/functions scripts vite.config.ts --ext ts,tsx --fix",
    "lint": "eslint src tests supabase/functions scripts vite.config.ts --ext ts,tsx --report-unused-disable-directives",
    "preview": "vite preview",
    "test": "vitest",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@mythicalb/ardor-core": "0.1.1",
    "@mythicalb/ardor-provider": "0.1.1",
    "@mythicalb/sdk": "0.1.3",
    "@supabase/supabase-js": "^2.49.4",
    "lucide-react": "^1.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-router-dom": "^7.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tailwindcss/postcss": "^4.1.4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "supabase": "^2.22.12",
    "tailwindcss": "^4.1.4",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.2.0",
    "vitest": "^3.1.1"
  }
}
